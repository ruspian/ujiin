// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GURU
}

enum Semester {
  GANJIL
  GENAP
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique 
  name      String
  password  String
  role      Role     @default(GURU)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  
  questions Question[] 
  exams     Exam[]     @relation("ExamAuthor")
  supervisedExams Exam[]  @relation("ExamSupervisor")

  subjectAssignments SubjectAssignment[]

  accounts  Account[]
  sessions  Session[]
}

model SchoolProfile {
  id            String   @id @default("1")
  name          String
  npsn          String?
  address       String?
  phone         String?
  updatedAt     DateTime @updatedAt
}

model Religion {
  id        String    @id @default(cuid())
  name      String    @unique 
  
  students  Student[] 
  subjects  Subject[] 

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


model Class {
  id        String    @id @default(cuid())
  name      String    
  level     Int       
  
  students  Student[] 
  exams     Exam[]   

  questions Question[]
  subjectAssignments SubjectAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  DROPOUT
  MUTATED 
}

model Student {
  id        String   @id @default(cuid())
  nisn      String   @unique 
  name      String

  password  String?
  
  session   String? 
  room      String?
  
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  
  attempts  Attempt[] 
  status  StudentStatus @default(ACTIVE)

  religionId String?
  religion   Religion? @relation(fields: [religionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id        String     @id @default(cuid())
  name      String     
  
  questions Question[] 
  exams     Exam[]    

  religionId String?
  religion   Religion? @relation(fields: [religionId], references: [id])

  assignments SubjectAssignment[]
}

model SubjectAssignment {
  id        String  @id @default(cuid())
  subjectId String
  classId   String
  teacherId String

  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // 1 Kelas cuma boleh punya 1 Guru untuk 1 Mapel yang sama
  @@unique([subjectId, classId]) 
}


model AcademicYear {
  id        String   @id @default(cuid())
  year      String   
  semester  Semester @default(GANJIL)
  active    Boolean  @default(false)
  
  exams     Exam[]   

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum QuestionType {
  MULTIPLE_CHOICE         
  MULTIPLE_CHOICE_COMPLEX 
  MATCHING                
  ESSAY                   
  TRUE_FALSE          
}

model Question {
  id            String   @id @default(cuid())
  text          String   @db.Text 
  options       Json     
  correctAnswer String  
  type          QuestionType @default(MULTIPLE_CHOICE)

  score         Int          @default(10)

  classId       String
  class         Class    @relation(fields: [classId], references: [id])

  examTypeId    String?  
  examType      ExamType? @relation(fields: [examTypeId], references: [id])
  
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])

  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])

  exams         Exam[]   

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ExamType {
  id        String   @id @default(cuid())
  name      String   
  code      String   @unique 
  
  exams     Exam[]  
  questions Question[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  COMPLETED
}

model Exam {
  id              String       @id @default(cuid())
  title           String    
  
  startTime       DateTime  
  endTime         DateTime  
  duration        Int       

  token           String?       @unique

  randomizeQuestions Boolean   @default(true) 
  showResult         Boolean   @default(false)
  status             ExamStatus @default(DRAFT)

  authorId        String
  author          User         @relation("ExamAuthor", fields: [authorId], references: [id])
  
  supervisorId    String?      
  supervisor      User?        @relation("ExamSupervisor", fields: [supervisorId], references: [id])

  subjectId       String
  subject         Subject      @relation(fields: [subjectId], references: [id])

  examTypeId      String
  examType        ExamType     @relation(fields: [examTypeId], references: [id])

  academicYearId  String
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])

  classes         Class[]     
  questions       Question[]  
  attempts        Attempt[]   

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Attempt {
  id          String    @id @default(cuid())
  startTime   DateTime  @default(now()) 
  endTime     DateTime? 
  score       Float?    
  answers     Json?     
  status      AttemptStatus @default(ONGOING) 
  
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id]) 

  violationCount  Int       @default(0)
  violationLogs   Json?
  
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id])

  @@unique([studentId, examId]) 
}

enum AttemptStatus {
  ONGOING   
  SUBMITTED 
  CHEATED   
}